    engine='python'
)

# Este dataset usa coma como separador decimal (formato europeo)
# Necesitamos convertirlo a punto para que Python lo entienda
COLS_NUMERICAS_TOP5 = [
    'Per 90 Minutes_xAG', 'Per 90 Minutes_Ast',
    'Progression_PrgP', 'Playing Time_Min',
    'Performance_Ast', 'Expected_xAG'
]
for col in COLS_NUMERICAS_TOP5:
    df_top5[col] = pd.to_numeric(
        df_top5[col].astype(str).str.replace(',', '.').str.replace(' ', ''),
        errors='coerce'
    )

# Filtrar Premier League + 900+ minutos
pl_mod = df_top5[
    (df_top5['league'] == 'ENG-Premier League') &
    (df_top5['Playing Time_Min'] >= 900)
].copy()

# Renombrar para consistencia con el dataset histórico
pl_mod = pl_mod.rename(columns={'player': 'Player', 'pos_': 'Pos'})
