# ------------------------------------------------------------
# CELDA 1: Librerías
# ------------------------------------------------------------

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import matplotlib.patheffects as pe
import warnings
warnings.filterwarnings('ignore')

# Estilo visual limpio y profesional
plt.rcParams.update({
    'figure.facecolor':  'white',
    'axes.facecolor':    'white',
    'axes.grid':         True,
    'grid.color':        '#E8E8E8',
    'grid.linewidth':    0.8,
    'font.family':       'sans-serif',
    'axes.spines.top':   False,
    'axes.spines.right': False,
})

# Paleta de colores por posición (consistente en todo el proyecto)
COLORES_POS = {
    'DF': '#2196F3',   # Azul  → defensores/laterales
    'MF': '#FF9800',   # Naranja → mediocampistas
    'FW': '#4CAF50',   # Verde → delanteros
    'GK': '#9E9E9E',   # Gris  → arqueros
}

print("✓ Librerías cargadas")


# ------------------------------------------------------------
# CELDA 2: Cargar y preparar el dataset
# ------------------------------------------------------------

# Cargá el archivo — si estás en Colab, primero subilo con:
# from google.colab import files; files.upload()
df = pd.read_csv('fbref_PL_202425.csv')

# --- Filtro de calidad: 900 minutos mínimos ---
# Equivale a ~10 partidos completos. Elimina jugadores con
# muestras demasiado pequeñas que distorsionan los promedios.
MIN_MINUTOS = 900
df_cal = df[df['Min'] >= MIN_MINUTOS].copy()

print(f"Dataset original  : {len(df)} jugadores")
print(f"Filtro 900+ min   : {len(df_cal)} jugadores")
print(f"Jugadores filtrados: {len(df) - len(df_cal)}")

# --- Posición principal ---
# FBref registra posiciones combinadas como "FW,MF" o "DF,MF".
# Tomamos el primer valor como posición dominante.
df_cal['Pos_principal'] = df_cal['Pos'].str.split(',').str[0]

# --- Métricas por 90 minutos ---
# Normalizar por tiempo jugado permite comparar jugadores
# con distinta cantidad de partidos de forma justa.
df_cal['xAG_90']  = (df_cal['xAG']  / df_cal['Min'] * 90).round(3)
df_cal['Ast_90']  = (df_cal['Ast']  / df_cal['Min'] * 90).round(3)
df_cal['PrgP_90'] = (df_cal['PrgP'] / df_cal['Min'] * 90).round(3)
df_cal['PrgC_90'] = (df_cal['PrgC'] / df_cal['Min'] * 90).round(3)
df_cal['Gls_90']  = (df_cal['Gls']  / df_cal['Min'] * 90).round(3)

print("\nColumnas calculadas: xAG_90, Ast_90, PrgP_90, PrgC_90, Gls_90")
print("\nDistribución de posiciones (900+ min):")
print(df_cal['Pos_principal'].value_counts())


# ------------------------------------------------------------
# CELDA 3: Resumen estadístico por posición
# ------------------------------------------------------------

print("\n" + "=" * 60)
print("PROMEDIOS POR POSICIÓN — PL 2024-25 (900+ min)")
print("=" * 60)

metricas = ['xAG_90', 'Ast_90', 'PrgP_90', 'PrgC_90', 'Gls_90']
resumen = (
    df_cal
    .groupby('Pos_principal')[metricas]
    .agg(['mean', 'median'])
    .round(3)
)
resumen.columns = ['_'.join(c) for c in resumen.columns]
resumen['n'] = df_cal.groupby('Pos_principal')['Player'].count()

print(resumen.sort_values('xAG_90_mean', ascending=False).to_string())

# --- Insight clave: medianas de xAG_90 ---
mediana_df = df_cal[df_cal['Pos_principal'] == 'DF']['xAG_90'].median()
mediana_mf = df_cal[df_cal['Pos_principal'] == 'MF']['xAG_90'].median()
mediana_fw = df_cal[df_cal['Pos_principal'] == 'FW']['xAG_90'].median()

print(f"\nMediana xAG/90 por posición:")
print(f"  FW: {mediana_fw:.3f}")
print(f"  MF: {mediana_mf:.3f}")
print(f"  DF: {mediana_df:.3f}")
print(f"\n→ Un mediocampista mediano genera {mediana_mf/mediana_df:.1f}x más xAG/90 que un defensor mediano")
print(f"→ Pero el MEJOR defensor (TAA: 0.278) supera al mediocampista mediano en {0.278/mediana_mf:.1f}x")


# ------------------------------------------------------------
# CELDA 4: Top creadores globales
# ------------------------------------------------------------

print("\n" + "=" * 60)
print("TOP 20 CREADORES DE JUEGO — PL 2024-25 (xAG/90)")
print("=" * 60)

# Excluimos arqueros del ranking de creadores
top20 = (
    df_cal[df_cal['Pos_principal'] != 'GK']
    .nlargest(20, 'xAG_90')
    [['Player', 'Pos_principal', 'Squad', 'Min', 'Ast', 'xAG', 'xAG_90', 'PrgP']]
)
print(top20.to_string(index=False))

# Composición del top 20
print(f"\nComposición del Top 20 creadores:")
for pos, count in top20['Pos_principal'].value_counts().items():
    print(f"  {pos}: {count} jugadores ({count/20*100:.0f}%)")

# Cuántos DF superan la mediana de los MF
df_beats_mf = (df_cal[df_cal['Pos_principal']=='DF']['xAG_90'] > mediana_mf).sum()
total_df = len(df_cal[df_cal['Pos_principal']=='DF'])
print(f"\nDefensores que superan la mediana de los MF en xAG/90:")
print(f"  {df_beats_mf} de {total_df} ({df_beats_mf/total_df*100:.0f}%)")


# ------------------------------------------------------------
# CELDA 5: Visualización 1 — Distribución de xAG/90 por posición
# ------------------------------------------------------------
# Violin plot: muestra distribución completa + mediana
# Es más informativo que un bar chart para comparar grupos

fig, ax = plt.subplots(figsize=(10, 6))

posiciones = ['DF', 'MF', 'FW']
datos_violin = [
    df_cal[df_cal['Pos_principal'] == pos]['xAG_90'].values
    for pos in posiciones
]

# Violin plot
vp = ax.violinplot(
    datos_violin,
    positions=[1, 2, 3],
    showmedians=True,
    showextrema=False,
    widths=0.6,
)

# Colorear cada violín según posición
for i, (body, pos) in enumerate(zip(vp['bodies'], posiciones)):
    body.set_facecolor(COLORES_POS[pos])
    body.set_alpha(0.35)
    body.set_edgecolor(COLORES_POS[pos])

vp['cmedians'].set_color('#333333')
vp['cmedians'].set_linewidth(2)

# Scatter de puntos individuales (jitter manual para no solapar)
np.random.seed(42)
for i, (pos, datos) in enumerate(zip(posiciones, datos_violin), 1):
    jitter = np.random.uniform(-0.12, 0.12, len(datos))
    ax.scatter(
        i + jitter, datos,
        alpha=0.4, s=18,
        color=COLORES_POS[pos],
        zorder=3
    )

# Anotar a Trent Alexander-Arnold como caso extremo
taa = df_cal[df_cal['Player'].str.contains('Alexander-Arnold')]
if len(taa) > 0:
    taa_val = taa['xAG_90'].values[0]
    ax.annotate(
        'Trent Alexander-Arnold\n(0.278 xAG/90)',
        xy=(1, taa_val),
        xytext=(1.45, taa_val + 0.03),
        fontsize=9,
        color='#1565C0',
        arrowprops=dict(arrowstyle='->', color='#1565C0', lw=1.2),
    )

ax.set_xticks([1, 2, 3])
ax.set_xticklabels(['Defensores (DF)', 'Mediocampistas (MF)', 'Delanteros (FW)'], fontsize=11)
ax.set_ylabel('xAG por 90 minutos', fontsize=11)
ax.set_title(
    '¿Murió el 10? — Distribución de creación de juego por posición\nPremier League 2024-25 (jugadores con 900+ min)',
    fontsize=13, fontweight='bold', pad=15
)

# Leyenda con medianas
for pos in posiciones:
    med = df_cal[df_cal['Pos_principal'] == pos]['xAG_90'].median()
    ax.text(
        posiciones.index(pos) + 1,
        -0.01,
        f'Mediana: {med:.3f}',
        ha='center', va='top', fontsize=9,
        color=COLORES_POS[pos], fontweight='bold',
        transform=ax.get_xaxis_transform()
    )

plt.tight_layout()
plt.savefig('viz1_distribucion_xAG_posicion.png', dpi=150, bbox_inches='tight')
plt.show()
print("✓ Visualización 1 guardada: viz1_distribucion_xAG_posicion.png")


# ------------------------------------------------------------
# CELDA 6: Visualización 2 — Scatter PrgP vs xAG coloreado por posición
# ------------------------------------------------------------
# Este gráfico es el corazón del análisis:
# muestra que algunos DF (laterales) viven en territorio
# que antes era exclusivo de los MF.

fig, ax = plt.subplots(figsize=(11, 7))

# Graficar cada posición como capa separada (GK al fondo)
for pos in ['GK', 'DF', 'MF', 'FW']:
    sub = df_cal[df_cal['Pos_principal'] == pos]
    ax.scatter(
        sub['PrgP_90'], sub['xAG_90'],
        c=COLORES_POS[pos],
        alpha=0.55 if pos != 'GK' else 0.2,
        s=45 if pos != 'GK' else 20,
        label=pos,
        zorder=3 if pos != 'GK' else 1,
    )

# Anotar jugadores destacados
jugadores_destacar = [
    ('Alexander-Arnold', '#1565C0', (-30, 8)),
    ('Bruno Fernandes',  '#E65100', (5, 5)),
    ('Kevin De Bruyne',  '#E65100', (5, -15)),
    ('Cole Palmer',      '#E65100', (5, 5)),
    ('Rayan Aït-Nouri',  '#1565C0', (5, 5)),
    ('Pedro Porro',      '#1565C0', (-80, 8)),
]

for nombre, color, offset in jugadores_destacar:
    j = df_cal[df_cal['Player'].str.contains(nombre.split()[-1])]
    if len(j) > 0:
        row = j.iloc[0]
        ax.annotate(
            row['Player'],
            xy=(row['PrgP_90'], row['xAG_90']),
            xytext=(row['PrgP_90'] + offset[0]/100, row['xAG_90'] + offset[1]/100),
            fontsize=8, color=color,
            arrowprops=dict(arrowstyle='->', color=color, lw=0.8),
        )

# Líneas de referencia: medianas por posición
ax.axhline(mediana_mf, color=COLORES_POS['MF'], lw=1, ls='--', alpha=0.5)
ax.text(
    ax.get_xlim()[1] if ax.get_xlim()[1] > 0 else 6,
    mediana_mf + 0.005,
    'Mediana MF',
    color=COLORES_POS['MF'], fontsize=8, alpha=0.8
)

# Leyenda
leyenda = [
    mpatches.Patch(color=COLORES_POS[p], label=p, alpha=0.7)
    for p in ['DF', 'MF', 'FW', 'GK']
]
ax.legend(handles=leyenda, title='Posición', fontsize=10)

ax.set_xlabel('Pases progresivos por 90 min (PrgP/90)', fontsize=11)
ax.set_ylabel('xAG por 90 minutos', fontsize=11)
ax.set_title(
    'El lateral como creador de juego — PL 2024-25\nPases progresivos vs Expected Assisted Goals por posición',
    fontsize=13, fontweight='bold', pad=15
)

plt.tight_layout()
plt.savefig('viz2_scatter_PrgP_xAG.png', dpi=150, bbox_inches='tight')
plt.show()
print("✓ Visualización 2 guardada: viz2_scatter_PrgP_xAG.png")


# ------------------------------------------------------------
# CELDA 7: Visualización 3 — Top 15 defensores vs top 15 MF
# ------------------------------------------------------------
# Bar chart horizontal con los mejores de cada posición
# para que el lector de LinkedIn pueda ver nombres concretos

fig, axes = plt.subplots(1, 2, figsize=(14, 7))

for ax, pos, titulo in zip(
