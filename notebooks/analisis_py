            f'{val:.3f}',
            va='center', fontsize=8.5,
            color='#333333'
        )

    # Línea de referencia: mediana del grupo contrario
    otro_pos = 'MF' if pos == 'DF' else 'DF'
    otra_mediana = df_cal[df_cal['Pos_principal'] == otro_pos]['xAG_90'].median()
    ax.axvline(
